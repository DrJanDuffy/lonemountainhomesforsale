# Optional: override RealScout office/agent id (base64) if different from default
NEXT_PUBLIC_REALSCOUT_AGENT_ID=

# Google Search Console — HTML tag verification: paste only the content value (not the meta tag)
GOOGLE_SITE_VERIFICATION=

# Optional: Google My Maps — paste full iframe src URL from Share → Embed (overrides site-contact defaults)
# NEXT_PUBLIC_OPEN_HOUSES_MAP_VIEWER_URL should use the same map id (mid=...) as the embed, viewer form:
# https://www.google.com/maps/d/u/0/viewer?mid=YOUR_MAP_ID
NEXT_PUBLIC_OPEN_HOUSES_MAP_EMBED_SRC=
NEXT_PUBLIC_OPEN_HOUSES_MAP_VIEWER_URL=
